{
  "name": "Contact page",
  "purpose": "A page where visitors find your phone, email, and address — optionally with an enquiry form.",
  "kind": "page",
  "variants": [
    { "key": "withForm", "label": "Details + an enquiry form" },
    { "key": "detailsOnly", "label": "Details only, with a call-us banner" }
  ],
  "inputs": [
    { "key": "menuLabel", "label": "Menu label", "type": "text", "required": true, "maxLength": 20,
      "example": "Contact" },
    { "key": "title", "label": "Page heading", "type": "text", "required": true, "maxLength": 70,
      "example": "Get in touch" },
    { "key": "intro", "label": "One-sentence introduction (also shown to search engines)", "type": "textarea", "required": true, "maxLength": 160,
      "example": "Call, email, or send us a message — we reply within one business day." },
    { "key": "address", "label": "Street address", "type": "text", "required": true, "maxLength": 120,
      "example": "12 Main Street, Springfield" },
    { "key": "formAction", "label": "Form endpoint URL", "type": "text", "required": true, "maxLength": 200,
      "pattern": "^https://", "hint": "a form service URL starting with https:// (e.g. from formspree.io)",
      "example": "https://formspree.io/f/your-form-id",
      "variants": ["withForm"] }
  ],
  "template": {
    "withForm": {
      "navLabel": "{{menuLabel}}",
      "meta": { "title": "{{title}} | {{site.name}}", "description": "{{intro}}" },
      "blocks": [
        { "id": "header", "type": "page-header", "fields": {
          "tag": "Contact", "heading": "{{title}}", "subhead": "{{intro}}"
        } },
        { "id": "info", "type": "contact-info", "fields": {
          "items": [
            { "id": "info-phone", "icon": "phone", "label": "Call", "value": "{{site.contact.phone}}", "href": "tel:{{site.contact.phone}}" },
            { "id": "info-email", "icon": "mail", "label": "Email", "value": "{{site.contact.email}}", "href": "mailto:{{site.contact.email}}" },
            { "id": "info-address", "icon": "pin", "label": "Visit", "value": "{{address}}" }
          ]
        } },
        { "id": "form", "type": "contact-form", "fields": {
          "tag": "Send a message",
          "heading": "How can we help?",
          "formAction": "{{formAction}}",
          "subjectLine": "Website enquiry — {{site.name}}",
          "fields": [
            { "name": "name", "label": "Full Name", "type": "text", "required": true, "half": true },
            { "name": "email", "label": "Email", "type": "email", "required": true, "half": true },
            { "name": "message", "label": "Your message", "type": "textarea", "required": true }
          ],
          "submitLabel": "Send"
        } }
      ]
    },
    "detailsOnly": {
      "navLabel": "{{menuLabel}}",
      "meta": { "title": "{{title}} | {{site.name}}", "description": "{{intro}}" },
      "blocks": [
        { "id": "header", "type": "page-header", "fields": {
          "tag": "Contact", "heading": "{{title}}", "subhead": "{{intro}}"
        } },
        { "id": "info", "type": "contact-info", "fields": {
          "items": [
            { "id": "info-phone", "icon": "phone", "label": "Call", "value": "{{site.contact.phone}}", "href": "tel:{{site.contact.phone}}" },
            { "id": "info-email", "icon": "mail", "label": "Email", "value": "{{site.contact.email}}", "href": "mailto:{{site.contact.email}}" },
            { "id": "info-address", "icon": "pin", "label": "Visit", "value": "{{address}}" }
          ]
        } },
        { "id": "cta", "type": "cta", "fields": {
          "statement": "Fastest answer? Give us a call.",
          "subtext": "{{site.contact.phone}}",
          "button": { "label": "Call now", "href": "tel:{{site.contact.phone}}", "style": "primary" }
        } }
      ]
    }
  }
}
