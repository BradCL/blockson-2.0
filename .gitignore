node_modules/
dist/
test-results/
clients/_candidate/
clients/*__candidate/
# Throwaway clients/themes created by validators and proofs (cleaned up in
# finally blocks, but a hard crash mid-run can leave them behind).
clients/__*/
themes/__theme-validate/
# Per-client maintenance ledger (owner-editor attempt log). The git history
# already records what shipped; the ledger's unique value is the attempts
# that DIDN'T — developer telemetry, not client-repo content (OPERATOR.md §9).
clients/*/edits.log*.jsonl
*.bak
.DS_Store
# Per-developer editor config (e.g. VS Code Live Server port) — machine-local
# tooling state, not project source.
.vscode/
# Per-client seed inlined by engine/build-demo.js for the browser demo bundle —
# regenerated on every build:demo, never source.
engine/ui/demo/seed.generated.js
# Owner-launcher runtime artifacts (extras/owner-launcher), written at the repo
# root on the owner's machine when the editor is launched — transient, not source.
.editor-out.log
.editor-err.log
.editor-browser/
# Test copies of the launcher scripts dropped at the repo root per the install
# runbook. Their canonical home is extras/owner-launcher/; root copies are
# throwaway test drops and must never be committed from here.
/Edit My Site.vbs
/editor-launcher.ps1
# Local-only developer working notes and scaffolding — never published.
_work/
.local/
# Testing-only copy of an external tester's site, dropped in to run the editor
# against. Its canonical home is its own client repo; copy a fresh one in by
# hand when needed (it is not part of this engine repo's tracked clients).
clients/hive-contracting/
