{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://blockson.engine/content.schema.json",
  "title": "Blockson content.json",
  "type": "object",
  "required": ["site", "pages"],
  "additionalProperties": false,
  "properties": {
    "site": {
      "type": "object",
      "required": ["name", "baseUrl", "theme", "logo", "contact", "nav", "footer", "copyright"],
      "additionalProperties": false,
      "properties": {
        "name":      { "type": "string" },
        "baseUrl":   { "type": "string", "format": "uri" },
        "theme":     { "type": "string" },
        "logo": {
          "type": "object",
          "required": ["white", "black", "favicon"],
          "additionalProperties": false,
          "properties": {
            "white":   { "type": "string" },
            "black":   { "type": "string" },
            "favicon": { "type": "string" }
          }
        },
        "contact": {
          "type": "object",
          "required": ["phone", "email"],
          "additionalProperties": false,
          "properties": {
            "phone":    { "type": "string" },
            "email":    { "type": "string" },
            "facebook": { "type": "string" },
            "instagram": { "type": "string" }
          }
        },
        "nav": {
          "type": "object",
          "required": ["links"],
          "additionalProperties": false,
          "properties": {
            "links": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["label", "href"],
                "additionalProperties": false,
                "properties": {
                  "label": { "type": "string" },
                  "href":  { "$ref": "#/$defs/safeHref" }
                }
              }
            },
            "cta": {
              "type": "object",
              "required": ["label", "href"],
              "additionalProperties": false,
              "properties": {
                "label": { "type": "string" },
                "href":  { "$ref": "#/$defs/safeHref" }
              }
            }
          }
        },
        "footer": {
          "type": "object",
          "required": ["blurb", "columns"],
          "additionalProperties": false,
          "properties": {
            "blurb": { "type": "string" },
            "columns": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["heading", "items"],
                "additionalProperties": false,
                "properties": {
                  "heading": { "type": "string" },
                  "items": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["label"],
                      "additionalProperties": false,
                      "properties": {
                        "label": { "type": "string" },
                        "href":  { "$ref": "#/$defs/safeHref" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "copyright":      { "type": "string" },
        "tagline":        { "type": "string" },
        "themeOverrides": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["slug", "meta", "blocks"],
        "additionalProperties": false,
        "properties": {
          "slug": { "type": "string" },
          "meta": {
            "type": "object",
            "required": ["title", "description"],
            "additionalProperties": false,
            "properties": {
              "title":       { "type": "string" },
              "description": { "type": "string" },
              "ogImage":     { "type": "string" }
            }
          },
          "blocks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "type", "fields"],
              "additionalProperties": false,
              "properties": {
                "id":     { "type": "string" },
                "type": {
                  "type": "string",
                  "enum": [
                    "hero","page-header","text","card-grid","gallery","testimonials",
                    "list-panel","service-area","contact-cards","contact-info",
                    "contact-form","cta",
                    "pricing-table","team-grid","faq","hours-table","before-after",
                    "stats-bar","process-steps","video-embed","booking-cta",
                    "photo-strip"
                  ]
                },
                "fields": { "type": "object" }
              },
              "allOf": [
                {
                  "if":   { "properties": { "type": { "const": "hero" } },         "required": ["type"] },
                  "then": { "properties": { "fields": { "$ref": "#/$defs/heroFields" } } }
                },
                {
                  "if":   { "properties": { "type": { "const": "page-header" } },  "required": ["type"] },
                  "then": { "properties": { "fields": { "$ref": "#/$defs/pageHeaderFields" } } }
                },
                {
                  "if":   { "properties": { "type": { "const": "text" } },         "required": ["type"] },
                  "then": { "properties": { "fields": { "$ref": "#/$defs/textFields" } } }
                },
                {
                  "if":   { "properties": { "type": { "const": "card-grid" } },    "required": ["type"] },
                  "then": { "properties": { "fields": { "$ref": "#/$defs/cardGridFields" } } }
                },
                {
                  "if":   { "properties": { "type": { "const": "gallery" } },      "required": ["type"] },
                  "then": { "properties": { "fields": { "$ref": "#/$defs/galleryFields" } } }
                },
                {
                  "if":   { "properties": { "type": { "const": "testimonials" } }, "required": ["type"] },
                  "then": { "properties": { "fields": { "$ref": "#/$defs/testimonialsFields" } } }
                },
                {
                  "if":   { "properties": { "type": { "const": "list-panel" } },   "required": ["type"] },
                  "then": { "properties": { "fields": { "$ref": "#/$defs/listPanelFields" } } }
                },
                {
                  "if":   { "properties": { "type": { "const": "service-area" } }, "required": ["type"] },
                  "then": { "properties": { "fields": { "$ref": "#/$defs/serviceAreaFields" } } }
                },
                {
                  "if":   { "properties": { "type": { "const": "contact-cards" } },"required": ["type"] },
                  "then": { "properties": { "fields": { "$ref": "#/$defs/contactCardsFields" } } }
                },
                {
                  "if":   { "properties": { "type": { "const": "contact-info" } }, "required": ["type"] },
                  "then": { "properties": { "fields": { "$ref": "#/$defs/contactInfoFields" } } }
                },
                {
                  "if":   { "properties": { "type": { "const": "contact-form" } }, "required": ["type"] },
                  "then": { "properties": { "fields": { "$ref": "#/$defs/contactFormFields" } } }
                },
                {
                  "if":   { "properties": { "type": { "const": "cta" } },          "required": ["type"] },
                  "then": { "properties": { "fields": { "$ref": "#/$defs/ctaFields" } } }
                },
                {
                  "if":   { "properties": { "type": { "const": "pricing-table" } },"required": ["type"] },
                  "then": { "properties": { "fields": { "$ref": "#/$defs/pricingTableFields" } } }
                },
                {
                  "if":   { "properties": { "type": { "const": "team-grid" } },    "required": ["type"] },
                  "then": { "properties": { "fields": { "$ref": "#/$defs/teamGridFields" } } }
                },
                {
                  "if":   { "properties": { "type": { "const": "faq" } },          "required": ["type"] },
                  "then": { "properties": { "fields": { "$ref": "#/$defs/faqFields" } } }
                },
                {
                  "if":   { "properties": { "type": { "const": "hours-table" } },  "required": ["type"] },
                  "then": { "properties": { "fields": { "$ref": "#/$defs/hoursTableFields" } } }
                },
                {
                  "if":   { "properties": { "type": { "const": "before-after" } }, "required": ["type"] },
                  "then": { "properties": { "fields": { "$ref": "#/$defs/beforeAfterFields" } } }
                },
                {
                  "if":   { "properties": { "type": { "const": "stats-bar" } },    "required": ["type"] },
                  "then": { "properties": { "fields": { "$ref": "#/$defs/statsBarFields" } } }
                },
                {
                  "if":   { "properties": { "type": { "const": "process-steps" } },"required": ["type"] },
                  "then": { "properties": { "fields": { "$ref": "#/$defs/processStepsFields" } } }
                },
                {
                  "if":   { "properties": { "type": { "const": "video-embed" } },  "required": ["type"] },
                  "then": { "properties": { "fields": { "$ref": "#/$defs/videoEmbedFields" } } }
                },
                {
                  "if":   { "properties": { "type": { "const": "booking-cta" } },  "required": ["type"] },
                  "then": { "properties": { "fields": { "$ref": "#/$defs/bookingCtaFields" } } }
                },
                {
                  "if":   { "properties": { "type": { "const": "photo-strip" } },   "required": ["type"] },
                  "then": { "properties": { "fields": { "$ref": "#/$defs/photoStripFields" } } }
                }
              ]
            }
          }
        }
      }
    }
  },
  "$defs": {
    "buttonStyle": { "type": "string", "enum": ["primary", "secondary"] },
    "safeHref": {
      "type": "string",
      "pattern": "^(?:(?:https?://|mailto:|tel:|sms:|#).*|[^:]*)$"
    },
    "action": {
      "type": "object",
      "required": ["label", "href", "style"],
      "additionalProperties": false,
      "properties": {
        "label": { "type": "string" },
        "href":  { "$ref": "#/$defs/safeHref" },
        "style": { "$ref": "#/$defs/buttonStyle" }
      }
    },
    "heroFields": {
      "type": "object",
      "required": ["tag", "headline", "subhead", "background"],
      "additionalProperties": false,
      "properties": {
        "hidden":  { "type": "boolean" },
        "tag":        { "type": "string" },
        "headline":   { "type": "string" },
        "subhead":    { "type": "string" },
        "background": { "type": "string" },
        "actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/action" }
        }
      }
    },
    "pageHeaderFields": {
      "type": "object",
      "required": ["tag", "heading"],
      "additionalProperties": false,
      "properties": {
        "hidden":  { "type": "boolean" },
        "tag":        { "type": "string" },
        "heading":    { "type": "string" },
        "subhead":    { "type": "string" },
        "background": { "type": "string" },
        "variant":    { "type": "string", "enum": ["default", "light"] }
      }
    },
    "textFields": {
      "type": "object",
      "required": ["body"],
      "additionalProperties": false,
      "properties": {
        "hidden":  { "type": "boolean" },
        "tag":     { "type": "string" },
        "heading": { "type": "string" },
        "body": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      }
    },
    "cardGridFields": {
      "type": "object",
      "required": ["cards"],
      "additionalProperties": false,
      "properties": {
        "hidden":  { "type": "boolean" },
        "tag":     { "type": "string" },
        "heading": { "type": "string" },
        "columns": { "type": "integer", "enum": [2, 3] },
        "cards": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "title"],
            "additionalProperties": false,
            "properties": {
              "id":    { "type": "string" },
              "icon":  { "type": "string" },
              "title": { "type": "string" },
              "body":  { "type": "string" },
              "items": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "galleryFields": {
      "type": "object",
      "required": ["filters", "albums"],
      "additionalProperties": false,
      "properties": {
        "hidden":  { "type": "boolean" },
        "tag":     { "type": "string" },
        "heading": { "type": "string" },
        "filters": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["label", "value"],
            "additionalProperties": false,
            "properties": {
              "label": { "type": "string" },
              "value": { "type": "string" }
            }
          }
        },
        "albums": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "category", "title", "images"],
            "additionalProperties": false,
            "properties": {
              "id":       { "type": "string" },
              "category": { "type": "string" },
              "title":    { "type": "string" },
              "meta":     { "type": "string" },
              "images": {
                "type": "array",
                "items": { "type": "string" },
                "minItems": 1
              }
            }
          }
        }
      }
    },
    "testimonialsFields": {
      "type": "object",
      "required": ["quotes"],
      "additionalProperties": false,
      "properties": {
        "hidden":  { "type": "boolean" },
        "tag":     { "type": "string" },
        "heading": { "type": "string" },
        "quotes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "quote", "attribution"],
            "additionalProperties": false,
            "properties": {
              "id":          { "type": "string" },
              "stars":       { "type": "integer", "minimum": 1, "maximum": 5 },
              "quote":       { "type": "string" },
              "attribution": { "type": "string" }
            }
          }
        }
      }
    },
    "listPanelFields": {
      "type": "object",
      "required": ["items"],
      "additionalProperties": false,
      "properties": {
        "hidden":  { "type": "boolean" },
        "tag":     { "type": "string" },
        "heading": { "type": "string" },
        "items": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      }
    },
    "serviceAreaFields": {
      "type": "object",
      "required": ["heading", "areas"],
      "additionalProperties": false,
      "properties": {
        "hidden":  { "type": "boolean" },
        "heading":     { "type": "string" },
        "body":        { "type": "string" },
        "areas": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "mapEmbedUrl": { "type": "string", "pattern": "^https://" }
      }
    },
    "contactCardsFields": {
      "type": "object",
      "required": ["cards"],
      "additionalProperties": false,
      "properties": {
        "hidden":  { "type": "boolean" },
        "cards": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "title", "cta"],
            "additionalProperties": false,
            "properties": {
              "id":   { "type": "string" },
              "icon":  { "type": "string" },
              "title": { "type": "string" },
              "body":  { "type": "string" },
              "items": {
                "type": "array",
                "items": { "type": "string" }
              },
              "note": { "type": "string" },
              "cta":  { "$ref": "#/$defs/action" }
            }
          }
        }
      }
    },
    "contactInfoFields": {
      "type": "object",
      "required": ["items"],
      "additionalProperties": false,
      "properties": {
        "hidden":  { "type": "boolean" },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "label", "value"],
            "additionalProperties": false,
            "properties": {
              "id":    { "type": "string" },
              "icon":  { "type": "string" },
              "label": { "type": "string" },
              "value": { "type": "string" },
              "href":  { "$ref": "#/$defs/safeHref" }
            }
          }
        }
      }
    },
    "contactFormFields": {
      "type": "object",
      "required": ["fields"],
      "additionalProperties": false,
      "if": {
        "required": ["delivery"],
        "properties": {
          "delivery": {
            "type": "object",
            "required": ["mode"],
            "properties": { "mode": { "const": "netlify" } }
          }
        }
      },
      "else": { "required": ["formAction"] },
      "properties": {
        "hidden":  { "type": "boolean" },
        "tag":         { "type": "string" },
        "heading":     { "type": "string" },
        "formAction":  { "type": "string", "pattern": "^https://" },
        "delivery": {
          "type": "object",
          "required": ["mode"],
          "additionalProperties": false,
          "properties": {
            "mode":        { "type": "string", "enum": ["endpoint", "netlify"] },
            "formName":    { "type": "string", "pattern": "^[A-Za-z0-9_-]+$" },
            "successPath": { "type": "string", "pattern": "^[^:]*$" }
          }
        },
        "subjectLine": { "type": "string" },
        "submitLabel": { "type": "string" },
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "label", "type"],
            "additionalProperties": false,
            "properties": {
              "name":        { "type": "string" },
              "label":       { "type": "string" },
              "type":        { "type": "string", "enum": ["text","email","tel","textarea","select"] },
              "required":    { "type": "boolean" },
              "placeholder": { "type": "string" },
              "options": {
                "type": "array",
                "items": { "type": "string" }
              },
              "half": { "type": "boolean" }
            }
          }
        }
      }
    },
    "ctaFields": {
      "type": "object",
      "required": ["statement", "button"],
      "additionalProperties": false,
      "properties": {
        "hidden":  { "type": "boolean" },
        "tag":       { "type": "string" },
        "statement": { "type": "string" },
        "subtext":   { "type": "string" },
        "button":    { "$ref": "#/$defs/action" }
      }
    },
    "pricingTableFields": {
      "type": "object",
      "required": ["plans"],
      "additionalProperties": false,
      "properties": {
        "hidden":  { "type": "boolean" },
        "tag":     { "type": "string" },
        "heading": { "type": "string" },
        "note":    { "type": "string" },
        "plans": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "name", "price"],
            "additionalProperties": false,
            "properties": {
              "id":          { "type": "string" },
              "name":        { "type": "string" },
              "price":       { "type": "string" },
              "period":      { "type": "string" },
              "description": { "type": "string" },
              "features": {
                "type": "array",
                "items": { "type": "string" }
              },
              "cta":      { "$ref": "#/$defs/action" },
              "featured": { "type": "boolean" }
            }
          }
        }
      }
    },
    "teamGridFields": {
      "type": "object",
      "required": ["members"],
      "additionalProperties": false,
      "properties": {
        "hidden":  { "type": "boolean" },
        "tag":     { "type": "string" },
        "heading": { "type": "string" },
        "members": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "name", "role"],
            "additionalProperties": false,
            "properties": {
              "id":    { "type": "string" },
              "photo": { "type": "string" },
              "name":  { "type": "string" },
              "role":  { "type": "string" },
              "bio":   { "type": "string" }
            }
          }
        }
      }
    },
    "faqFields": {
      "type": "object",
      "required": ["items"],
      "additionalProperties": false,
      "properties": {
        "hidden":  { "type": "boolean" },
        "tag":     { "type": "string" },
        "heading": { "type": "string" },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "question", "answer"],
            "additionalProperties": false,
            "properties": {
              "id":       { "type": "string" },
              "question": { "type": "string" },
              "answer":   { "type": "string" }
            }
          }
        }
      }
    },
    "hoursTableFields": {
      "type": "object",
      "required": ["rows"],
      "additionalProperties": false,
      "properties": {
        "hidden":  { "type": "boolean" },
        "tag":     { "type": "string" },
        "heading": { "type": "string" },
        "note":    { "type": "string" },
        "rows": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "day", "hours"],
            "additionalProperties": false,
            "properties": {
              "id":    { "type": "string" },
              "day":   { "type": "string" },
              "hours": { "type": "string" }
            }
          }
        }
      }
    },
    "beforeAfterFields": {
      "type": "object",
      "required": ["pairs"],
      "additionalProperties": false,
      "properties": {
        "hidden":  { "type": "boolean" },
        "tag":     { "type": "string" },
        "heading": { "type": "string" },
        "pairs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "before", "after"],
            "additionalProperties": false,
            "properties": {
              "id":      { "type": "string" },
              "title":   { "type": "string" },
              "before":  { "type": "string" },
              "after":   { "type": "string" },
              "caption": { "type": "string" }
            }
          }
        }
      }
    },
    "photoStripFields": {
      "type": "object",
      "required": ["photos"],
      "additionalProperties": false,
      "properties": {
        "hidden":  { "type": "boolean" },
        "tag":     { "type": "string" },
        "heading": { "type": "string" },
        "photos": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "image"],
            "additionalProperties": false,
            "properties": {
              "id":    { "type": "string" },
              "image": { "type": "string" }
            }
          }
        }
      }
    },
    "statsBarFields": {
      "type": "object",
      "required": ["stats"],
      "additionalProperties": false,
      "properties": {
        "hidden":  { "type": "boolean" },
        "stats": {
          "type": "array",
          "minItems": 2,
          "maxItems": 4,
          "items": {
            "type": "object",
            "required": ["id", "value", "label"],
            "additionalProperties": false,
            "properties": {
              "id":    { "type": "string" },
              "value": { "type": "string" },
              "label": { "type": "string" }
            }
          }
        }
      }
    },
    "processStepsFields": {
      "type": "object",
      "required": ["steps"],
      "additionalProperties": false,
      "properties": {
        "hidden":  { "type": "boolean" },
        "tag":     { "type": "string" },
        "heading": { "type": "string" },
        "steps": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "required": ["id", "title", "body"],
            "additionalProperties": false,
            "properties": {
              "id":    { "type": "string" },
              "icon":  { "type": "string" },
              "title": { "type": "string" },
              "body":  { "type": "string" }
            }
          }
        }
      }
    },
    "videoEmbedFields": {
      "type": "object",
      "required": ["videoUrl"],
      "additionalProperties": false,
      "properties": {
        "hidden":  { "type": "boolean" },
        "tag":     { "type": "string" },
        "heading": { "type": "string" },
        "videoUrl": {
          "type": "string",
          "pattern": "^https://(www\\.)?(youtube\\.com/embed/|youtube-nocookie\\.com/embed/|player\\.vimeo\\.com/video/)[A-Za-z0-9_\\-?=&]+$"
        },
        "caption": { "type": "string" }
      }
    },
    "bookingCtaFields": {
      "type": "object",
      "required": ["statement", "button"],
      "additionalProperties": false,
      "properties": {
        "hidden":  { "type": "boolean" },
        "tag":       { "type": "string" },
        "statement": { "type": "string" },
        "subtext":   { "type": "string" },
        "provider":  { "type": "string" },
        "note":      { "type": "string" },
        "button": {
          "type": "object",
          "required": ["label", "href"],
          "additionalProperties": false,
          "properties": {
            "label": { "type": "string" },
            "href":  { "type": "string", "pattern": "^https://" }
          }
        }
      }
    }
  }
}
