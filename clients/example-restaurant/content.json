            "heading": "Common questions",
            "items": [
              {
                "id": "faq-reservations",
                "question": "Do you take reservations?",
                "answer": "Yes — online through OpenTable, or by phone for groups of seven or more. We hold a third of the room for walk-ins every night."
              },
              {
                "id": "faq-dietary",
                "question": "Can you handle allergies and dietary restrictions?",
                "answer": "Almost always. The menu marks gluten-free and vegetarian options, and the kitchen keeps a dedicated prep space for celiac guests. Tell us when you book."
              },
              {
                "id": "faq-parking",
                "question": "Where do I park?",
                "answer": "Free street parking on 104 Street after 6pm, and the Garneau lot is half a block east. We validate for the lot on weekends."
              },
              {
                "id": "faq-kids",
                "question": "Are kids welcome?",
                "answer": "Absolutely — high chairs, a half-portion menu, and crayons that have drawn on every tablecloth since 2014."
              }
